# ── Required ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Database (Neon Postgres) ───────────────────────────────────────────────────
# Get from: neon.tech → your project → Connection Details → copy "Connection string"
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ── Auth / security (CHANGE THESE before going live) ──────────────────────────
# Generate JWT_SECRET with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_DAYS=30
# Secret needed to mint redemption codes via POST /api/admin/generate-codes
ADMIN_KEY=change-me-admin-key

# ── Free-tier monthly limits (Pro/Lifetime = unlimited) ───────────────────────
FREE_REPORTS_PER_MONTH=3
FREE_COVER_LETTERS_PER_MONTH=2
FREE_JD_PER_MONTH=2
FREE_COMPARE_PER_MONTH=1

# ── Optional ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
RATE_LIMIT=60/hour
